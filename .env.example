# Copy to .env and fill in real values. Never commit .env.
# Cesium Ion access token: https://ion.cesium.com/tokens
CESIUM_TOKEN=your-cesium-ion-token

# Google Maps Tile API key (Photorealistic 3D Tiles)
# Restrict by HTTP referrer in Google Cloud Console.
GOOGLE_KEY=your-google-maps-tiles-key

# Optional: override listen port (default 8080)
# PORT=8080
